{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/contracts/simulation-output.schema.json",
  "title": "CallCenterSimulationOutput",
  "type": "object",
  "required": ["meta", "scenarios", "comparison"],
  "properties": {
    "meta": {
      "type": "object",
      "required": ["generated_at", "engine_version", "base_seed", "scenario_count"],
      "properties": {
        "run_id": { "type": ["string", "null"] },
        "generated_at": { "type": "string", "format": "date-time" },
        "engine_version": { "type": "string" },
        "base_seed": { "type": "integer", "minimum": 0 },
        "scenario_count": { "type": "integer", "minimum": 1 }
      },
      "additionalProperties": true
    },
    "scenarios": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["meta", "scenario", "replications", "aggregates", "timeseries"],
        "properties": {
          "meta": {
            "type": "object",
            "properties": {
              "run_id": { "type": ["string", "null"] },
              "generated_at": { "type": "string", "format": "date-time" },
              "engine_version": { "type": "string" },
              "random_seed_policy": { "type": "string" }
            },
            "additionalProperties": true
          },
          "scenario": {
            "type": "object",
            "required": ["scenario_id", "name", "parameters"],
            "properties": {
              "scenario_id": { "type": "string" },
              "name": { "type": "string" },
              "parameters": { "type": "object" }
            },
            "additionalProperties": true
          },
          "replications": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["replication_id", "seed", "kpis"],
              "properties": {
                "replication_id": { "type": "integer", "minimum": 1 },
                "seed": { "type": "integer", "minimum": 0 },
                "kpis": { "type": "object" }
              },
              "additionalProperties": true
            }
          },
          "aggregates": {
            "type": "object",
            "required": ["kpis", "confidence_intervals_95"],
            "properties": {
              "kpis": { "type": "object" },
              "confidence_intervals_95": { "type": "object" }
            },
            "additionalProperties": true
          },
          "timeseries": {
            "type": "object",
            "properties": {
              "queue_length": { "type": "array" },
              "utilization": { "type": "array" },
              "throughput": { "type": "array" }
            },
            "additionalProperties": true
          }
        },
        "additionalProperties": true
      }
    },
    "comparison": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["scenario_id", "scenario_name"],
        "properties": {
          "scenario_id": { "type": "string" },
          "scenario_name": { "type": "string" },
          "avg_wait_seconds": { "type": "number" },
          "abandonment_rate": { "type": "number" },
          "sla_compliance_rate": { "type": "number" },
          "utilization_tier1": { "type": "number" },
          "utilization_tier2": { "type": "number" }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
